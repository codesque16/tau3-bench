ANTHROPIC_API_KEY=<your_key_here>
OPENAI_API_KEY=<your_key_here>
ELEVENLABS_API_KEY=<your_key_here>
DEEPGRAM_API_KEY=<your_key_here>

# Required for banking_knowledge qwen_embeddings* retrieval configs (via OpenRouter)
OPENROUTER_API_KEY=<your_key_here>

# Vertex AI (used by --agent vertex_agent via google.genai SDK)
VERTEXAI_PROJECT=<your_gcp_project_id>
VERTEXAI_LOCATION=global
# Optional: GenAI 429/5xx retry (truncated exponential backoff in genai_logfire)
# TAU2_GENAI_MAX_RETRIES=8
# TAU2_GENAI_RETRY_BASE_S=1.0
# TAU2_GENAI_RETRY_MAX_S=60.0
